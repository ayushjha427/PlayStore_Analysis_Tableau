      <aliases enabled='yes' />
      <column caption='Clean Installs' datatype='integer' name='[Calculation_1057257520209920]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(&#10;REPLACE(&#10;REPLACE([Installs],&quot;,&quot;,&quot;&quot;),&#10;&quot;+&quot;,&quot;&quot;&#10;)&#10;)' />
      </column>
      <column caption='Clean_Size' datatype='real' name='[Calculation_1057257521434626]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF CONTAINS([Size],&quot;M&quot;) THEN&#10;FLOAT(REPLACE([Size],&quot;M&quot;,&quot;&quot;))&#10;&#10;ELSEIF CONTAINS([Size],&quot;k&quot;) THEN&#10;FLOAT(REPLACE([Size],&quot;k&quot;,&quot;&quot;))/1024&#10;&#10;END' />
      </column>
      <column caption='High_RatedApps' datatype='string' name='[Calculation_1057257521635331]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Rating] &gt;= 4 THEN&#10;&quot;High Rated&quot;&#10;ELSE&#10;&quot;Low Rated&quot;&#10;END' />
      </column>
      <column caption='Install Bucket' datatype='string' name='[Calculation_1057257522069510]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1057257520209920] &lt; 10000 THEN&#10;&quot;Low&quot;&#10;&#10;ELSEIF [Calculation_1057257520209920] &lt; 1000000 THEN&#10;&quot;Medium&quot;&#10;&#10;ELSE&#10;&quot;High&quot;&#10;END' />
      </column>
      <column caption='Updated Year' datatype='integer' datatype-customized='true' name='[Calculation_1057257522282503]' role='dimension' type='quantitative'>
        <calculation class='tableau' formula='YEAR([Last Updated])' />
      </column>
      <column caption='Free App %' datatype='real' default-format='p0.0%' name='[Calculation_1057257527017480]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#10;IF [Type] = &quot;Free&quot;&#10;THEN [App]&#10;END&#10;)&#10;/&#10;COUNT([App])' />
      </column>
      <column caption='HighRatedApps' datatype='integer' name='[Calculation_1057257529712649]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#10;IF [Rating] &gt;= 4&#10;THEN [App]&#10;END&#10;)' />
      </column>
